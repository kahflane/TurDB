{
  "workflow": {
    "codeQualityRules": {
      "documentation": "80-100 line block comment at top of each file. No inline comments. Doc comments (///) for public API only.",
      "errorHandling": "Use eyre exclusively. Every error must include context (operation, resource, reason). No custom error enums.",
      "followPatterns": "Study existing code in src/ directories. Follow established patterns. Reference Go implementation for logic.",
      "naming": "Follow Rust naming conventions. snake_case for functions/variables, PascalCase for types.",
      "noPartialWork": "Each task must be 100% complete before marking done=true",
      "noPlaceholders": "NEVER write TODO comments or placeholder implementations. Complete each task fully.",
      "testsMustPass": "All tests must pass before committing. Run 'cargo test' to verify",
      "zeroAllocation": "CRUD operations must not allocate. Use arenas for query-scoped allocations.",
      "zeroCopy": "Return &[u8] slices from mmap. Never clone page data."
    },
    "commitConvention": {
      "examples": [
        "feat(storage): implement SIEVE cache eviction algorithm",
        "feat(btree): add slot array with prefix hints for fast lookup",
        "test(hnsw): add benchmarks for SQ8 quantized distance",
        "fix(mvcc): correct version chain visibility check"
      ],
      "format": "<type>(<scope>): <description>",
      "scopes": [
        "storage - Storage engine (pager, mmap, cache, wal)",
        "btree - B-tree index implementation",
        "hnsw - HNSW vector index",
        "mvcc - Transaction/concurrency",
        "sql - SQL parser/planner/executor",
        "record - Row serialization",
        "schema - Catalog and schema management",
        "api - Public API",
        "cli - Command-line interface"
      ],
      "types": {
        "docs": "Documentation updates",
        "feat": "New feature implementation",
        "fix": "Bug fix",
        "perf": "Performance improvement",
        "refactor": "Code refactoring without behavior change",
        "test": "Adding or updating tests"
      }
    },
    "concurrency": {
      "avoidConflicts": "Before starting, check 'git worktree list' for active feature worktrees",
      "cleanup": "After merging a feature, remove the worktree: 'git worktree remove ./tur-feature-<name>'",
      "mergeStrategy": "Each feature worktree is isolated. After completion, merge from the worktree or create PR",
      "multipleAgents": "Multiple agents can work on DIFFERENT features simultaneously using git worktrees",
      "worktreeNaming": "Directory: ./tur-feature-<feature-title-kebab-case>, Branch: feature/<feature-title-kebab-case>"
    },
    "mandatorySteps": {
      "beforeStarting": [
        "Read this entire workflow section carefully",
        "Check active worktrees: run 'git worktree list' to see active feature worktrees",
        "Pick ONE feature where isCompleted=false AND no worktree exists for it",
        "Review CLAUDE.md for Rust-specific guidelines",
        "Review migration.md for architectural context"
      ],
      "implementationCycle": [
        "STEP 1: Create feature worktree with dedicated directory",
        "  Note: Worktree directory: /Users/julfikar/Documents/PassionFruit.nosync/tur/rust/.worktrees",
        "  → Run: git worktree add ./.worktrees/tur-feature-<feature-title-kebab-case> -b feature/<feature-title-kebab-case>",
        "  → Change directory: cd ./.worktrees/tur-feature-<feature-title-kebab-case>",
        "",
        "STEP 2: For EACH task in the feature.tasks array (in order):",
        "  ",
        "  2a. ANALYZE THE TASK",
        "     → Read the task description carefully",
        "     → Identify what files need to be created/modified",
        "     → Check Go implementation in ../pkg/ for logic reference",
        "     → Review CLAUDE.md for Rust-specific patterns",
        "  ",
        "  2b. WRITE TEST FIRST (RED phase)",
        "     → Create or update test module in tests/ directory",
        "     → Write specific test case for this task",
        "     → Run: cargo test",
        "     → VERIFY test FAILS (if it passes, test is wrong or task already done)",
        "  ",
        "  2c. IMPLEMENT CODE (GREEN phase)",
        "     → Write MINIMAL code to make the test pass",
        "     → Ensure zero-copy and zero-allocation where required",
        "     → Focus on making THIS test pass",
        "     → Run: cargo test",
        "     → VERIFY test now PASSES",
        "  ",
        "  2d. REFACTOR (if needed)",
        "     → Clean up code while keeping tests green",
        "     → Run: cargo clippy -- -D warnings",
        "     → Run: cargo fmt",
        "     → Run: cargo test (ensure still passing)",
        "  ",
        "  2e. UPDATE FEATURE LIST",
        "     → Edit rust/.claude/feature-list.json",
        "     → Find this exact task in the feature",
        "     → Change 'done': false to 'done': true",
        "  ",
        "  2f. COMMIT",
        "     → Run: git add .",
        "     → Run: git commit -m 'feat(<scope>): <task-description>'",
        "  ",
        "  REPEAT 2a-2f for ALL tasks in the feature",
        "",
        "STEP 3: Complete feature",
        "  → Verify ALL tasks have 'done': true",
        "  → Run: cargo test",
        "  → Run: cargo clippy -- -D warnings",
        "  → Run: cargo build --release",
        "  → Update feature-list.json: set 'isCompleted': true",
        "  → Commit: git commit -m 'feat(<scope>): complete feature implementation'",
        "",
        "STEP 4: Report completion",
        "  → List completed tasks",
        "  → Show test results",
        "  → Report any blockers or dependencies discovered"
      ]
    },
    "method": "TDD (Test-Driven Development)",
    "objective": "Achieve CONCRETE, WORKING implementation of TurDB Rust features. Zero-copy, zero allocation, 16KB pages, 1MB RAM minimum.",
    "referenceResources": {
      "goImplementation": [
        "../pkg/pager/ - Page management reference",
        "../pkg/btree/ - B-tree implementation reference",
        "../pkg/hnsw/ - HNSW index reference",
        "../pkg/mvcc/ - MVCC implementation reference"
      ],
      "projectDocs": [
        "CLAUDE.md - Rust-specific development guidelines",
        "migration.md - Architecture and migration plan"
      ],
      "testExamples": "Look at Rust crate tests for testing patterns"
    },
    "testingGuidelines": {
      "coverage": "Aim for >80% code coverage per module",
      "examples": [
        "#[test] fn sieve_cache_evicts_unvisited_first() { ... }",
        "#[test] fn btree_slot_array_finds_by_prefix() { ... }",
        "#[test] fn record_zero_copy_text_access() { ... }"
      ],
      "location": "Tests in #[cfg(test)] mod tests { } at end of file, or tests/ directory for integration",
      "naming": "fn test_function_scenario() with snake_case",
      "structure": "Arrange-Act-Assert pattern"
    },
    "troubleshooting": {
      "conflictingWorktree": "Feature worktree already exists? Pick a different feature.",
      "lifetimeErrors": "Borrow checker issues? Review CLAUDE.md zero-copy patterns. Consider arena allocation.",
      "missingDependencies": "Task depends on another incomplete feature? Note as blocker. Implement dependency first.",
      "testWontFail": "Test passes immediately? Either task is already done, or test isn't testing the right thing.",
      "testWontPass": "Can't make test pass? Break task into smaller steps. Study Go implementation.",
      "worktreeCleanup": "When done: 'git worktree remove <path>' to clean up"
    }
  },
